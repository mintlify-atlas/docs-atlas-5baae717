  "keyFeatures": [
    "Intelligent auto-scheduling that finds optimal time slots for tasks based on work hours, energy levels, and calendar availability",
    "Two-way calendar sync with Google Calendar, Microsoft Outlook, and CalDAV servers",
    "Task management with projects, tags, priorities, energy levels, and recurrence rules",
    "Focus mode for distraction-free task execution",
    "Multiple calendar views (day, week, month, multi-month)",
    "Docker-based self-hosting with PostgreSQL",
    "Optional SaaS hosted version with Stripe billing and waitlist management",
    "Import/export support for data portability"
  ],
  "publicApiSurface": [
    "GET /api/tasks — List tasks",
    "POST /api/tasks — Create task",
    "PUT /api/tasks/:id — Update task",
    "DELETE /api/tasks/:id — Delete task",
    "GET /api/events — List calendar events",
    "POST /api/events — Create calendar event",
    "GET /api/calendar — List calendar feeds",
    "POST /api/calendar/google — Connect Google Calendar",
    "POST /api/auto-schedule-settings — Update auto-schedule settings",
    "POST /api/task-sync — Trigger task sync",
    "GET /api/projects — List projects",
    "POST /api/projects — Create project",
    "GET /api/tags — List tags",
    "POST /api/import — Import calendar/task data",
    "GET /api/export — Export data",
    "GET /api/settings — Get system settings",
    "POST /api/setup — Initial application setup"
  ]
